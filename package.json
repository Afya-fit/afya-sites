{
  "name": "@afya/sites",
  "version": "1.0.0",
  "description": "Afya Sites - Site Builder and Renderer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:builder && npm run build:renderer",
    "build:builder": "webpack --config webpack.builder.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "dev": "concurrently \"npm run dev:builder\" \"npm run dev:renderer\"",
    "dev:builder": "webpack serve --config webpack.builder.config.js",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "afya",
    "sites",
    "site-builder",
    "renderer"
  ],
  "author": "Afya",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "html-webpack-plugin": "^5.0.0",
    "jest": "^29.0.0",
    "style-loader": "^3.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^4.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
